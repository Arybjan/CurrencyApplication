<Page x:Class="CurrencyApplication.Views.CurrencyListPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="CurrencyListPage">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Список валют"
                   FontSize="24"
                   FontWeight="Bold"
                   Margin="0,0,0,15"/>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Margin="0,0,0,10">
            <Button Content="Загрузить с API"
                    Width="150"
                    Height="35"
                    Margin="0,0,10,0"
                    Command="{Binding LoadFromApiCommand}"/>

            <Button Content="Обновить локальные"
                    Width="160"
                    Height="35"
                    Margin="0,0,10,0"
                    Command="{Binding ReloadLocalDataCommand}"/>

            <Button Content="Удалить"
                    Width="100"
                    Height="35"
                    Margin="0,0,10,0"
                    Command="{Binding DeleteCurrencyCommand}"/>

            <Button Content="Переключить хранилище"
                    Width="190"
                    Height="35"
                    Margin="0,0,10,0"
                    Command="{Binding SwitchStorageCommand}"/>
        </StackPanel>

        <StackPanel Grid.Row="2"
                    Orientation="Vertical"
                    Margin="0,0,0,10">
            <TextBlock Text="{Binding LastSessionText}"
                       FontSize="14"
                       Margin="0,0,0,5"/>

            <TextBlock FontSize="14">
                <Run Text="Текущее хранилище: "/>
                <Run Text="{Binding StorageType}"/>
            </TextBlock>
        </StackPanel>

        <DataGrid Grid.Row="3"
                  ItemsSource="{Binding Currencies}"
                  SelectedItem="{Binding SelectedCurrency}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  SelectionMode="Single"
                  SelectionUnit="FullRow">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Id"
                                    Binding="{Binding Id}"
                                    Width="100"/>

                <DataGridTextColumn Header="CharCode"
                                    Binding="{Binding CharCode}"
                                    Width="100"/>

                <DataGridTextColumn Header="Название"
                                    Binding="{Binding Name}"
                                    Width="220"/>

                <DataGridTextColumn Header="Номинал"
                                    Binding="{Binding Nominal}"
                                    Width="100"/>

                <DataGridTextColumn Header="Курс"
                                    Binding="{Binding Value}"
                                    Width="120"/>

                <DataGridTextColumn Header="Предыдущий"
                                    Binding="{Binding Previous}"
                                    Width="120"/>

                <DataGridCheckBoxColumn Header="Пользовательская"
                                        Binding="{Binding IsUserAdded}"
                                        Width="140"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>